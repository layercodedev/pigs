{
  "name": "pigs",
  "version": "0.2.0",
  "description": "TUI for managing parallel Claude Code agents in git worktrees",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "pigs": "src/index.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "typecheck": "bun x tsc --noEmit",
    "test": "bash -c 'bun test $(ls src/__tests__/*.test.ts | grep -v integration)'",
    "test:integration": "bun test src/__tests__/integration.test.ts --timeout 120000"
  },
  "dependencies": {
    "blessed": "^0.1.81"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/bun": "^1.3.8"
  }
}
